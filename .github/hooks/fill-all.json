{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/hooks/session-context.sh",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "./scripts/hooks/user-prompt-audit.sh",
        "timeout": 5
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "./scripts/hooks/pre-tool-audit.sh",
        "timeout": 15
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "./scripts/hooks/post-tool-audit.sh",
        "timeout": 10
      }
    ]
  }
}
